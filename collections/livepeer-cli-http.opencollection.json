          "info": {
            "name": "Rebond tokens",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "http://localhost:5935/rebond",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Rebond tokens in unbonding state"
